# --- Server ---
PORT=3000
# Comma-separated list of allowed CORS origins for the frontend
CORS_ORIGIN=http://localhost:4200

# --- Anthropic (Claude) ranking ---
# Get a key at https://console.anthropic.com/
# Without it the app falls back to keyword-based scoring.
ANTHROPIC_API_KEY=
# Model used for ranking. Haiku is cheap and fast; good default for scoring.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- GitHub source (free) ---
# Optional. Without a token GitHub search is rate-limited to ~10 req/min.
# Create a fine-grained token (no scopes needed for public search) at
# https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Web / X-ray source (SerpAPI) ---
# Get a key at https://serpapi.com/ (free tier available).
# Without it, the "web" source is skipped (returns no results — never mocks).
SERPAPI_KEY=
