# --- Server ---
PORT=3000
# Comma-separated list of allowed CORS origins for the frontend
CORS_ORIGIN=http://localhost:4200

# --- LLM ranking (pick ONE; app uses whichever key is set) ---
# Option A: Anthropic (Claude) — best quality, requires prepaid billing.
#   https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Option B: Google Gemini — FREE tier, no credit card. Get a key at
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# If neither key is set, the app ranks by keyword matching (still real data).

# --- GitHub source (free) ---
# Optional. Without a token GitHub search is rate-limited to ~10 req/min.
# Create a fine-grained token (no scopes needed for public search) at
# https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Web / X-ray source (pick ONE; app uses whichever key is set) ---
# Option A: Serper.dev — FREE 2500 queries, no credit card.
#   https://serper.dev/
SERPER_API_KEY=
# Option B: SerpAPI — free tier (~100/mo).
#   https://serpapi.com/
SERPAPI_KEY=
# With no key, the web source is skipped (returns nothing — never mocks).
